### Component 2: Database Schema (PostgreSQL)

#### [NEW] `infra/schema.sql` — Full Production Schema

```sql
-- Users (central identity)
CREATE TABLE users (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  email TEXT UNIQUE NOT NULL,
  name TEXT NOT NULL,
  role TEXT CHECK (role IN ('employee', 'employer', 'admin')) NOT NULL,
  tier TEXT CHECK (tier IN ('free', 'pro')) DEFAULT 'free',
  google_id TEXT UNIQUE,
  verified BOOLEAN DEFAULT FALSE,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Employee extended profiles
CREATE TABLE employee_profiles (
  user_id UUID PRIMARY KEY REFERENCES users(id) ON DELETE CASCADE,
  photo_url TEXT,
  linkedin_url TEXT,
  github_url TEXT,
  location TEXT,
  availability TEXT CHECK (availability IN ('immediate', '15_days', '30_days', '60_plus')),
  salary_expectation_lpa NUMERIC(10,2),
  experience_level TEXT CHECK (experience_level IN ('fresher', 'junior', 'mid', 'senior')),
  tech_stacks TEXT[],   -- array of skill tags
  education_level TEXT CHECK (education_level IN ('diploma', 'bachelor', 'master', 'phd')),
  is_visible_to_employers BOOLEAN DEFAULT TRUE,  -- PII consent flag
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Employer extended profiles
CREATE TABLE employer_profiles (
  user_id UUID PRIMARY KEY REFERENCES users(id) ON DELETE CASCADE,
  company_name TEXT NOT NULL,
  employer_name TEXT NOT NULL,
  designation TEXT NOT NULL,
  company_address TEXT,
  company_email TEXT NOT NULL,
  payment_status TEXT CHECK (payment_status IN ('pending', 'active', 'expired')) DEFAULT 'pending',
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Onboarding answers (30 questions)
CREATE TABLE onboarding_answers (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID REFERENCES users(id) ON DELETE CASCADE,
  question_id INTEGER NOT NULL,
  answer_text TEXT,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  UNIQUE(user_id, question_id)
);

-- CV analysis results
CREATE TABLE cv_analyses (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID REFERENCES users(id) ON DELETE CASCADE,
  cv_file_path TEXT NOT NULL,
  cv_file_name TEXT,
  jd_text TEXT,
  jd_file_path TEXT,
  obtained_score NUMERIC(5,2),
  potential_score NUMERIC(5,2),
  negative_grade NUMERIC(5,2),
  analysis_json JSONB,       -- full breakdown per criterion
  suggestions_json JSONB,    -- actionable improvement checklist
  flagged_terms_json JSONB,  -- negative grade detail
  created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Communication test scores
CREATE TABLE communication_scores (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID REFERENCES users(id) ON DELETE CASCADE,
  mcq_grammar NUMERIC(5,2),
  mcq_verbal NUMERIC(5,2),
  mcq_shortforms NUMERIC(5,2),
  voice_grammar NUMERIC(5,2),
  voice_confidence NUMERIC(5,2),
  voice_speed_wpm NUMERIC(6,2),
  total_score NUMERIC(5,2),
  error_summary_json JSONB,   -- per-question error detail
  created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Company recommendations (Pro only)
CREATE TABLE company_suggestions (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID REFERENCES users(id) ON DELETE CASCADE,
  company_name TEXT NOT NULL,
  match_pct NUMERIC(5,2),
  reasoning_json JSONB,
  created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Payments (supports one-time & subscription)
CREATE TABLE payments (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID REFERENCES users(id) ON DELETE CASCADE,
  razorpay_order_id TEXT UNIQUE NOT NULL,
  razorpay_payment_id TEXT,
  razorpay_subscription_id TEXT,   -- null for one-time
  payment_type TEXT CHECK (payment_type IN ('one_time', 'subscription')) NOT NULL,
  amount NUMERIC(10,2) NOT NULL,
  currency TEXT DEFAULT 'INR',
  status TEXT CHECK (status IN ('created', 'paid', 'failed', 'refunded')) DEFAULT 'created',
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Employer shortlists
CREATE TABLE employer_shortlists (
  employer_id UUID REFERENCES users(id) ON DELETE CASCADE,
  candidate_id UUID REFERENCES users(id) ON DELETE CASCADE,
  shortlisted_at TIMESTAMPTZ DEFAULT NOW(),
  PRIMARY KEY (employer_id, candidate_id)
);

-- OTP verification log
CREATE TABLE otp_verification (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  email TEXT NOT NULL,
  otp_hash TEXT NOT NULL,
  expires_at TIMESTAMPTZ NOT NULL,
  used BOOLEAN DEFAULT FALSE,
  created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Indexes for employer candidate filter queries
CREATE INDEX idx_employee_profiles_tech ON employee_profiles USING GIN(tech_stacks);
CREATE INDEX idx_employee_profiles_location ON employee_profiles(location);
CREATE INDEX idx_cv_analyses_user ON cv_analyses(user_id, created_at DESC);
CREATE INDEX idx_comm_scores_user ON communication_scores(user_id, created_at DESC);
```

**Engineering notes:**
- `analysis_json` stored as JSONB for flexible breakdown schema as models evolve
- `tech_stacks` as `TEXT[]` with GIN index for efficient employer filter queries
- `is_visible_to_employers` on `employee_profiles` is the PII consent gate (resolves open question)
- Separate `otp_verification` table keeps Supabase Auth as source of truth while supporting custom OTP flow

